{
  "name": "talentforge-poc",
  "version": "0.1.0",
  "private": true,
  "description": "TalentForge AI — PoC para demos comerciales de reclutamiento con agentes",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "seed": "tsx scripts/seed-demo.ts",
    "seed:reset": "tsx scripts/reset-demo.ts",
    "db:types": "supabase gen types typescript --linked > packages/db/types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@talentforge/db": "workspace:*",
    "@types/ws": "^8.18.1",
    "openai": "^4.73.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "turbo": "^2.3.0",
    "typescript": "^5.4.5"
  }
}
